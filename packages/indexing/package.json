{
  "name": "@info-arnav/vox-indexing",
  "version": "1.0.1",
  "type": "module",
  "license": "MIT",
  "description": "Local file indexing, full-text search, and document parsing for Vox",
  "main": "./src/index.js",
  "private": false,
  "exports": {
    ".": "./src/index.js",
    "./db": "./src/db/db.js",
    "./search": "./src/db/search.js",
    "./files": "./src/ingest/files.js",
    "./parser": "./src/parser/pool.js",
    "./parser/worker": "./src/parser/worker.js",
    "./parser/docx": "./src/parser/parsers/docx.js",
    "./process": "./src/process/host.js",
    "./process/entry": "./src/process/process.js",
    "./ipc": "./src/runtime/ipc.js",
    "./logger": "./src/logger.js",
    "./sentry": "./src/sentry.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/info-arnav/vox"
  },
  "files": [
    "src",
    "LICENSE",
    "README.md"
  ],
  "peerDependencies": {
    "electron": ">=28.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "unpdf": "^1.4.0",
    "adm-zip": "^0.5.16"
  }
}
